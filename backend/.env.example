# =============================================================================
#  ANI-VOXA Backend — Environment Variables
#  Copy this file to .env and fill in the required values.
#
#  Required  → must be set before starting the server
#  Optional  → safe to leave blank (sensible defaults apply)
# =============================================================================


# -----------------------------------------------------------------------------
#  LLM PROVIDER
#  All providers use the OpenAI-compatible chat-completions format.
#  Switch by changing LLM_PROVIDER + LLM_API_KEY — no code changes needed.
#
#  Provider   Auto base URL                                   Default models
#  ---------  ----------------------------------------------  -------------------------
#  groq       https://api.groq.com/openai/v1                 llama-3.3-70b / llama-3.1-8b
#  openai     https://api.openai.com/v1                      gpt-4o / gpt-4o-mini
#  anthropic  https://api.anthropic.com/v1                   claude-3-5-sonnet / claude-3-haiku
#  together   https://api.together.xyz/v1                    Llama-3.3-70B / Llama-3.1-8B
#  deepseek   https://api.deepseek.com/v1                    deepseek-chat
#  gemini     https://generativelanguage.googleapis.com/...  gemini-1.5-pro / gemini-1.5-flash
#  ollama     http://localhost:11434/v1                       llama3.2
#  azure      (set LLM_BASE_URL to your Azure endpoint)      gpt-4o / gpt-4o-mini
# -----------------------------------------------------------------------------

LLM_PROVIDER=groq

# Required: API key for the chosen provider
# Groq (free tier) → https://console.groq.com
# OpenAI           → https://platform.openai.com/api-keys
LLM_API_KEY=your_api_key_here

# Optional: Override the base URL (only needed for Azure, Ollama, or custom endpoints)
# LLM_BASE_URL=https://your-resource.openai.azure.com/

# Optional: Override model names (defaults auto-selected per provider)
# PRIMARY_MODEL=llama-3.3-70b-versatile
# FALLBACK_MODEL=llama-3.1-8b-instant

# Optional: Feature flags (auto-detected from LLM_PROVIDER if blank)
# LLM_JSON_MODE=true
# LLM_SUPPORTS_STT=true
# STT_MODEL=whisper-large-v3

# Azure only
# AZURE_API_VERSION=2024-10-21


# -----------------------------------------------------------------------------
#  VISION  (image uploads — auto-configured per provider, override if needed)
#
#  Groq   → meta-llama/llama-4-scout-17b-16e-instruct  (default)
#  OpenAI → gpt-4o-mini  (default)
#  Leave blank to use the provider default above.
# -----------------------------------------------------------------------------

# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# VISION_API_KEY=         # defaults to LLM_API_KEY
# VISION_BASE_URL=        # defaults to LLM_BASE_URL


# -----------------------------------------------------------------------------
#  SERVER
# -----------------------------------------------------------------------------

HOST=0.0.0.0
PORT=8000
DEBUG_MODE=false

# Comma-separated list of allowed CORS origins
# CORS_ORIGINS=https://your-frontend.com

# Regex for allowed origins (default: localhost on any port for dev)
# CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$


# -----------------------------------------------------------------------------
#  MONGODB  (required for full functionality)
# -----------------------------------------------------------------------------

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB_NAME=db_name

# Collection name overrides (optional)
# MONGO_USERS_COLLECTION=users
# MONGO_CHATS_COLLECTION=chats


# -----------------------------------------------------------------------------
#  SUPABASE
# -----------------------------------------------------------------------------
STORAGE_BACKEND=supabase
SUPABASE_PUBLIC_BASE_URL=https://your-project.supabase.co
SUPABASE_URL=<your_supabase_url>
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>
SUPABASE_STORAGE_BUCKET=<your_supabase_storage_bucket>
ALLOWED_EMAIL_DOMAINS=<your_allowed_email_domains>  


# -----------------------------------------------------------------------------
#  AUTH  (JWT + Refresh Tokens)
# -----------------------------------------------------------------------------

# Change both secrets to long random strings in production!
JWT_SECRET=change-this-to-a-long-random-secret-in-production
REFRESH_TOKEN_SECRET=change-this-to-another-long-random-secret-in-production

# Access token TTL in minutes (default 60 = 1 hour)
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token TTL — remember_me=true → REFRESH_TOKEN_EXPIRE_DAYS
#                   — remember_me=false → REFRESH_TOKEN_SHORT_EXPIRE_DAYS
# REFRESH_TOKEN_EXPIRE_DAYS=30
# REFRESH_TOKEN_SHORT_EXPIRE_DAYS=1

# JWT_ALGORITHM=HS256


# -----------------------------------------------------------------------------
#  DATA INGESTION
# -----------------------------------------------------------------------------

# Path to the directory containing CSV/JSON data files to auto-ingest.
# Leave blank to use the default ../data (relative to backend/)
# DATA_DIR=/app/data


# -----------------------------------------------------------------------------
#  FILE STORAGE  (uploads)
# -----------------------------------------------------------------------------

# local = store on disk | supabase = store in Supabase Storage


# -----------------------------------------------------------------------------
#  CONVERSATION MEMORY
# -----------------------------------------------------------------------------

# memory = in-process (resets on restart) | redis = persistent across restarts
# MEMORY_BACKEND=memory

# Required only when MEMORY_BACKEND=redis
# REDIS_URL=redis://localhost:6379

# MEMORY_CONTEXT_WINDOW=6       # how many turns of history to inject into LLM
# MEMORY_MAX_INTERACTIONS=40    # max stored turns per session


# -----------------------------------------------------------------------------
#  ASSISTANT IDENTITY  (optional)
# -----------------------------------------------------------------------------

# ASSISTANT_NAME=Voxa


# -----------------------------------------------------------------------------
#  SEMANTIC SEARCH  (optional — two modes)
#
#  Mode 1 · LLM keyword expansion (always active, no config needed)
#    The orchestrator asks the LLM to generate synonym/jargon terms for every
#    query and merges them with the base keywords before the MongoDB search.
#    Requires no additional setup.
#
#  Mode 2 · Embedding vector search (opt-in)
#    Set EMBEDDING_MODEL to enable dense-vector semantic search via MongoDB
#    Atlas $vectorSearch.  Requires:
#      a) A MongoDB Atlas cluster (free tier works).
#      b) A vector search index on each data collection.
#      c) Documents pre-populated with their embedding vectors in EMBEDDING_FIELD.
#
#  Recommended embedding models:
#    Mistral → mistral-embed          (1024-dim, fast)
#    OpenAI  → text-embedding-3-small (1536-dim, fast, cheap)
#    OpenAI  → text-embedding-3-large (3072-dim, higher accuracy)
#    Ollama  → nomic-embed-text       (768-dim, runs locally)
#
#  If EMBEDDING_API_KEY is blank it falls back to LLM_API_KEY.
# -----------------------------------------------------------------------------

# EMBEDDING_MODEL=mistral-embed
# EMBEDDING_API_KEY=                        # defaults to LLM_API_KEY if blank
# EMBEDDING_BASE_URL=https://api.mistral.ai/v1
# EMBEDDING_FIELD=embedding                 # MongoDB field that holds the vector
# EMBEDDING_INDEX=rag_vector_index          # Atlas vector index name


# -----------------------------------------------------------------------------
#  ZOHO CRM  (disabled — see services/zoho_crm_service.py to re-enable)
#
#  Re-activation steps:
#   1. Fill in the values below and copy to .env.
#   2. Uncomment the full implementation in services/zoho_crm_service.py.
#   3. Uncomment the three "# ── ZOHO CRM ──" blocks in
#      orchestrator/query_orchestrator.py.
# -----------------------------------------------------------------------------

# ZOHO_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_ACCESS_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_REDIRECT_URI=http://localhost:8000/callback

# Data centre — change for US / EU / AU / JP / CA / SA
# ZOHO_BASE_URL=https://www.zohoapis.in/crm/v2
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.in/oauth/v2/token

# Module API names — update if your Zoho account uses custom module names
# ZOHO_PATIENTS_MODULE=Patient
# ZOHO_MEDICINES_MODULE=Medicines_Module
